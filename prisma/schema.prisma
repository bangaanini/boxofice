generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Movie {
  id             String            @id @default(uuid())
  sourceUrl      String            @unique
  title          String
  thumbnail      String?
  description    String?           @db.Text
  genre          String?
  year           String?
  duration       String?
  rating         String?
  quality        String?
  releaseDate    String?
  actors         String[]          @default([])
  directors      String[]          @default([])
  streams        String?           @db.Text
  detailSyncedAt DateTime?
  inHome         Boolean           @default(false)
  inPopular      Boolean           @default(false)
  inNew          Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  streamCache    MovieStreamCache?
  favorites      UserFavorite[]
  watchHistories WatchHistory[]

  @@index([updatedAt])
  @@index([inHome, updatedAt])
  @@index([inPopular, updatedAt])
  @@index([inNew, updatedAt])
  @@index([detailSyncedAt])
}

model MovieStreamCache {
  id           String   @id @default(uuid())
  movieId      String   @unique
  sourceUrl    String   @unique
  resolvedFrom String?  @db.Text
  originalUrl  String?  @db.Text
  iframe       String?  @db.Text
  m3u8         String?  @db.Text
  sources      Json     @db.JsonB
  checkedAt    DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  movie        Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([checkedAt])
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String
  passwordSalt String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     UserSession[]
  favorites    UserFavorite[]
  watchHistory WatchHistory[]
}

model UserSession {
  id         String   @id @default(uuid())
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model UserFavorite {
  id        String   @id @default(uuid())
  userId    String
  movieId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([userId, createdAt])
  @@index([movieId])
}

model WatchHistory {
  id              String   @id @default(uuid())
  userId          String
  movieId         String
  progressSeconds Int      @default(0)
  durationSeconds Int?
  completed       Boolean  @default(false)
  lastWatchedAt   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie           Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([userId, lastWatchedAt])
  @@index([movieId])
}
